# EditorConfig for TSFX Bridge SDK
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.lua]
indent_size = 4

[*.ts]
indent_size = 4

[*.{json,yaml,yml}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[fxmanifest.lua]
indent_size = 4
