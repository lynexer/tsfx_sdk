{
    "name": "tsfx-vscode-extension",
    "displayName": "TSFX SDK Support",
    "description": "VSCode extension for TSFX Bridge SDK development support",
    "version": "0.0.1",
    "private": true,
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:**/fxmanifest.lua"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "tsfx.helloWorld",
                "title": "Hello World",
                "category": "TSFX"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.3.0"
    }
}
