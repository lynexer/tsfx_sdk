{
    "TSFX Player Handle": {
        "prefix": "tsfx-player",
        "body": [
            "TSFX.Player(${1:source})"
        ],
        "description": "Create a TSFX Player handle"
    },
    "TSFX Add Money": {
        "prefix": "tsfx-add-money",
        "body": [
            ":addMoney('${1:bank}', ${2:100})"
        ],
        "description": "Add money to player (chainable)"
    },
    "TSFX Remove Money": {
        "prefix": "tsfx-remove-money",
        "body": [
            ":removeMoney('${1:bank}', ${2:100})"
        ],
        "description": "Remove money from player (chainable)"
    },
    "TSFX Set Money": {
        "prefix": "tsfx-set-money",
        "body": [
            ":setMoney('${1:bank}', ${2:100})"
        ],
        "description": "Set player money to exact amount (chainable)"
    },
    "TSFX Get Money": {
        "prefix": "tsfx-get-money",
        "body": [
            ":getMoney('${1:bank}')"
        ],
        "description": "Get player's money in specified account"
    },
    "TSFX Set Job": {
        "prefix": "tsfx-set-job",
        "body": [
            ":setJob('${1:job}', ${2:1})"
        ],
        "description": "Set player's job (chainable)"
    },
    "TSFX Get Job": {
        "prefix": "tsfx-get-job",
        "body": [
            ":getJob()"
        ],
        "description": "Get player's current job data"
    },
    "TSFX Set Gang": {
        "prefix": "tsfx-set-gang",
        "body": [
            ":setGang('${1:gang}', ${2:1})"
        ],
        "description": "Set player's gang (chainable)"
    },
    "TSFX Set Duty": {
        "prefix": "tsfx-set-duty",
        "body": [
            ":setDuty(${1:true})"
        ],
        "description": "Set player's on-duty status (chainable)"
    },
    "TSFX Set Metadata": {
        "prefix": "tsfx-set-metadata",
        "body": [
            ":setMetadata('${1:key}', ${2:value})"
        ],
        "description": "Set player metadata value (chainable)"
    },
    "TSFX Get Metadata": {
        "prefix": "tsfx-get-metadata",
        "body": [
            ":getMetadata('${1:key}')"
        ],
        "description": "Get player metadata value"
    },
    "TSFX Remove Metadata": {
        "prefix": "tsfx-remove-metadata",
        "body": [
            ":removeMetadata('${1:key}')"
        ],
        "description": "Remove player metadata value (chainable)"
    },
    "TSFX Drop Player": {
        "prefix": "tsfx-player-drop",
        "body": [
            ":drop('${1:reason}')"
        ],
        "description": "Drop player from server (chainable)"
    },
    "TSFX Set Position": {
        "prefix": "tsfx-set-position",
        "body": [
            ":setPosition(${1:vector3(x, y, z)})"
        ],
        "description": "Set player position (chainable)"
    },
    "TSFX Play Animation": {
        "prefix": "tsfx-play-anim",
        "body": [
            ":playAnimation('${1:dict}', '${2:name}', {",
            "    ${3:loop = true, upperBody = true}",
            "})"
        ],
        "description": "Play animation on player (client-only, chainable)"
    },
    "TSFX Clear Tasks": {
        "prefix": "tsfx-clear-tasks",
        "body": [
            ":clearTasks()"
        ],
        "description": "Clear player tasks (client-only, chainable)"
    },
    "TSFX Inventory Give Item": {
        "prefix": "tsfx-inventory-give",
        "body": [
            "TSFX.Inventory.giveItem(${1:source}, '${2:item}', ${3:1})"
        ],
        "description": "Give item to player via inventory"
    },
    "TSFX Inventory Remove Item": {
        "prefix": "tsfx-inventory-remove",
        "body": [
            "TSFX.Inventory.removeItem(${1:source}, '${2:item}', ${3:1})"
        ],
        "description": "Remove item from player via inventory"
    },
    "TSFX Inventory Has Item": {
        "prefix": "tsfx-inventory-has",
        "body": [
            "TSFX.Inventory.hasItem(${1:source}, '${2:item}', ${3:1})"
        ],
        "description": "Check if player has item"
    },
    "TSFX Inventory Get Item": {
        "prefix": "tsfx-inventory-get",
        "body": [
            "TSFX.Inventory.getItem(${1:source}, '${2:item}')"
        ],
        "description": "Get item data for player"
    },
    "TSFX Inventory Get All": {
        "prefix": "tsfx-inventory-all",
        "body": [
            "TSFX.Inventory.getInventory(${1:source})"
        ],
        "description": "Get full inventory for player"
    },
    "TSFX Notify Send": {
        "prefix": "tsfx-notify",
        "body": [
            "TSFX.Notify.send(${1:source}, '${2:message}', '${3:success}', ${4:5000})"
        ],
        "description": "Send notification to player"
    },
    "TSFX Notify Progress Start": {
        "prefix": "tsfx-notify-progress",
        "body": [
            "TSFX.Notify.progressStart(${1:source}, {",
            "    label = '${2:Doing something...}',",
            "    duration = ${3:5000},",
            "})"
        ],
        "description": "Start progress notification"
    },
    "TSFX Notify Progress Cancel": {
        "prefix": "tsfx-notify-progress-cancel",
        "body": [
            "TSFX.Notify.progressCancel(${1:source})"
        ],
        "description": "Cancel progress notification"
    },
    "TSFX EventBus On": {
        "prefix": "tsfx-event-on",
        "body": [
            "TSFX.EventBus.on('${1:event}', function(${2:...})",
            "    $0",
            "end)"
        ],
        "description": "Register internal event listener"
    },
    "TSFX EventBus Emit": {
        "prefix": "tsfx-event-emit",
        "body": [
            "TSFX.EventBus.emit('${1:event}', ${2:...})"
        ],
        "description": "Emit internal event"
    },
    "TSFX EventBus Emit Net": {
        "prefix": "tsfx-event-emit-net",
        "body": [
            "TSFX.EventBus.emitNet('${1:event}', ${2:...})"
        ],
        "description": "Emit networked event"
    },
    "TSFX EventBus Broadcast": {
        "prefix": "tsfx-event-broadcast",
        "body": [
            "TSFX.EventBus.broadcast('${1:event}', ${2:...})"
        ],
        "description": "Broadcast event to all clients (server-only)"
    },
    "TSFX EventBus Await": {
        "prefix": "tsfx-event-await",
        "body": [
            "TSFX.EventBus.await('${1:event}', ${2:...}, function(${3:response})",
            "    $0",
            "end)"
        ],
        "description": "Emit event and await callback response"
    },
    "TSFX Cache Set": {
        "prefix": "tsfx-cache-set",
        "body": [
            "TSFX.Cache.set('${1:key}', ${2:value}, ${3:60})"
        ],
        "description": "Store value in cache with optional TTL"
    },
    "TSFX Cache Get": {
        "prefix": "tsfx-cache-get",
        "body": [
            "TSFX.Cache.get('${1:key}')"
        ],
        "description": "Retrieve value from cache"
    },
    "TSFX Cache Has": {
        "prefix": "tsfx-cache-has",
        "body": [
            "TSFX.Cache.has('${1:key}')"
        ],
        "description": "Check if cache key exists"
    },
    "TSFX Cache Delete": {
        "prefix": "tsfx-cache-delete",
        "body": [
            "TSFX.Cache.delete('${1:key}')"
        ],
        "description": "Delete cache key"
    },
    "TSFX Cache Flush": {
        "prefix": "tsfx-cache-flush",
        "body": [
            "TSFX.Cache.flush()"
        ],
        "description": "Clear all public cache entries"
    },
    "TSFX Log": {
        "prefix": "tsfx-log",
        "body": [
            "TSFX.Log:${1|info,warn,error,debug|}('${2:message}')"
        ],
        "description": "Log message via TSFX logger"
    },
    "TSFX Locale": {
        "prefix": "tsfx-locale",
        "body": [
            "_('${1:key}', { ${2:...} })"
        ],
        "description": "Translate locale key"
    },
    "TSFX Framework Handle": {
        "prefix": "tsfx-framework",
        "body": [
            "TSFX.Framework():${1|GetName,GetVersion,GetAllJobs,GetAllGangs,HasGangs,FindPlayer,FindPlayerByCitizenId|}()"
        ],
        "description": "Call framework handle method"
    },
    "TSFX Streaming Model": {
        "prefix": "tsfx-streaming-model",
        "body": [
            "TSFX.Streaming.requestModel(${1:'model_name'}).asset"
        ],
        "description": "Request and get model hash (client-only)"
    },
    "TSFX Streaming With Model": {
        "prefix": "tsfx-streaming-with-model",
        "body": [
            "TSFX.Streaming.withModel(${1:'model_name'}, function(${2:modelHash})",
            "    $0",
            "end)"
        ],
        "description": "Request model scoped to callback (client-only)"
    },
    "TSFX Streaming Anim Dict": {
        "prefix": "tsfx-streaming-anim",
        "body": [
            "TSFX.Streaming.withAnimDict(${1:'dict_name'}, function(${2:dict})",
            "    $0",
            "end)"
        ],
        "description": "Request animation dictionary scoped to callback (client-only)"
    },
    "TSFX StateMachine": {
        "prefix": "tsfx-state-machine",
        "body": [
            "TSFX.StateMachine(${1:machineName}, {",
            "    initial = '${2:idle}',",
            "    transitions = {",
            "        { from = '${3:idle}', to = '${4:active}', guard = function(machine, ctx)",
            "            return ${5:true}",
            "        end },",
            "    },",
            "})"
        ],
        "description": "Create a TSFX StateMachine"
    }
}
